{
    "plugin": {
        "name": "SAM 3",
        "description": "Text-guided image/video matting with Meta SAM 3 / 3.1 — cut out every instance of a described concept.",
        "icon": "/plugins/tongflow-modal-sam3.svg"
    },
    "env": [
        {
            "key": "MODAL_TOKEN_ID",
            "required": true,
            "description": "Modal token id",
            "url": "https://modal.com/settings/tokens"
        },
        {
            "key": "MODAL_TOKEN_SECRET",
            "required": true,
            "description": "Modal token secret (paired with MODAL_TOKEN_ID)"
        },
        {
            "key": "HF_TOKEN",
            "required": true,
            "description": "Hugging Face token of an account granted access to facebook/sam3 and facebook/sam3.1",
            "url": "https://huggingface.co/facebook/sam3"
        },
        {
            "key": "TONGFLOW_MODAL_CALL_TIMEOUT_S",
            "default": "2400",
            "description": "Max seconds to wait for a Modal call"
        }
    ]
}
